generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId         String    @id @default(uuid()) @map("user_id") @db.VarChar(64)
  email          String    @unique @db.VarChar(256)
  passwordHash   String?   @map("password_hash") @db.VarChar(256)
  role           String    @db.VarChar(64)
  locationCode   String?   @map("location_code") @db.VarChar(32)
  isActive       Boolean   @default(true) @map("is_active")
  isLocked       Boolean   @default(false) @map("is_locked")
  mfaEnabled     Boolean   @default(false) @map("mfa_enabled")
  mfaSecret      String?   @map("mfa_secret") @db.VarChar(64)
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until") @db.Timestamptz
  lastLoginAt    DateTime? @map("last_login_at") @db.Timestamptz
  permissions    Json?
  metadata       Json?
  userPinHash    String?   @map("user_pin_hash") @db.VarChar(128)
  userPinSet     Boolean   @default(false) @map("user_pin_set")
  faceIdSet      Boolean   @default(false) @map("face_id_set")
  backupCodes    Json?     @map("backup_codes")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  
  authSessions AuthSession[]
  apiKeys      ApiKey[]
  appointments Appointments[]

  @@map("users")
}

model AuthSession {
  sessionId           String   @id @default(uuid()) @map("session_id") @db.VarChar(64)
  userId              String   @map("user_id") @db.VarChar(64)
  authMethod          String   @map("auth_method") @db.VarChar(32)
  role                String   @db.VarChar(64)
  locationCode        String?  @map("location_code") @db.VarChar(32)
  deviceId            String?  @map("device_id") @db.VarChar(128)
  ipAddress           String?  @map("ip_address") @db.VarChar(64)
  isActive            Boolean  @default(true) @map("is_active")
  isBreakGlass        Boolean  @default(false) @map("is_break_glass")
  hipaaGateConfirmed  Boolean  @default(false) @map("hipaa_gate_confirmed")
  expiresAt           DateTime @map("expires_at") @db.Timestamptz
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("auth_sessions")
}

model ApiKey {
  keyId      String    @id @default(uuid()) @map("key_id") @db.VarChar(64)
  userId     String    @map("user_id") @db.VarChar(64)
  name       String    @db.VarChar(128)
  keyHash    String    @unique @map("key_hash") @db.VarChar(64)
  keyPrefix  String    @map("key_prefix") @db.VarChar(12)
  scopes     Json?
  isActive   Boolean   @default(true) @map("is_active")
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("api_keys")
}

model RefreshToken {
  id              Int       @id @default(autoincrement())
  tokenHash       String    @unique @map("token_hash") @db.VarChar(64)
  sessionId       String    @map("session_id") @db.VarChar(64)
  userId          String    @map("user_id") @db.VarChar(64)
  issuedAt        DateTime  @default(now()) @map("issued_at") @db.Timestamptz
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz
  replacedByHash  String?   @map("replaced_by_hash") @db.VarChar(64)

  @@map("refresh_tokens")
}

model BreakGlassEvent {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id") @db.VarChar(64)
  sessionId String   @map("session_id") @db.VarChar(64)
  reason    String   @db.Text
  approved  Boolean  @default(true)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("break_glass_events")
}

model PatientToken {
  id              Int       @id @default(autoincrement())
  phoneHash       String    @map("phone_hash") @db.VarChar(64)
  otpHash         String    @map("otp_hash") @db.VarChar(64)
  otpExpiresAt    DateTime  @map("otp_expires_at") @db.Timestamptz
  patientToken    String?   @unique @map("patient_token") @db.VarChar(128)
  tokenExpiresAt  DateTime? @map("token_expires_at") @db.Timestamptz
  verified        Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("patient_tokens")
}

model Otp {
  id            Int      @id @default(autoincrement())
  recipient     String   @db.VarChar(256)
  recipientType String   @map("recipient_type") @db.VarChar(16)
  otpHash       String   @map("otp_hash") @db.VarChar(64)
  otpType       String   @default("login") @map("otp_type") @db.VarChar(32)
  expiresAt     DateTime @map("expires_at") @db.Timestamptz
  used          Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("otp")
}

model Appointments {
  appointmentId   String    @id @default(uuid()) @map("appointment_id") @db.VarChar(64)
  patientId       String    @map("patient_id") @db.VarChar(64)
  reason          String?   @db.Text
  insuranceName   String?   @map("insurance_name") @db.VarChar(200)
  providerName    String?   @map("provider_name") @db.VarChar(200)
  category        String?   @db.VarChar(200)
  appointmentType String?   @map("appointment_type") @db.VarChar(200)
  appointmentDate DateTime? @map("appointment_date") @db.Date
  timeSlot        String?   @map("time_slot") @db.VarChar(32)
  status          String    @default("Pending") @db.VarChar(32)
  deleted         Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  patient User @relation(fields: [patientId], references: [userId], onDelete: Cascade)

  @@map("appointments")
}
