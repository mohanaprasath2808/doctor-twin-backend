# Doctor Twin Backend — environment configuration
# Copy to .env: cp .env.example .env

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL (matches Python SESSION_DB_URL target)
DATABASE_URL=postgresql://postgres:root@localhost:5432/doctor_twin

# ── Auth (ported from doctor-twin-ai) ─────────────────────────────────────────
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7
STEP_UP_TOKEN_TTL_MINUTES=15
LOCKOUT_MINUTES=30
MFA_ISSUER=DoctorTwin
PATIENT_OTP_TTL_MINUTES=10
PATIENT_TOKEN_TTL_HOURS=24

# stub = return OTP in API responses (dev only); live = omit OTP from responses
INTEGRATION_MODE=stub
